{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reflect Dev",
  "identifier": "app.reflect.desktop.dev",
  "app": {
    "windows": [
      {
        "title": "Reflect Dev",
        "width": 1300,
        "height": 650,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false,
        "visible": false
      }
    ]
  },
  "bundle": {
    "icon": [
      "icons-dev/32x32.png",
      "icons-dev/128x128.png",
      "icons-dev/128x128@2x.png",
      "icons-dev/icon.icns",
      "icons-dev/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/team-reflect/reflect-open/releases/download/updater-dev-noop/latest.json"
      ]
    }
  }
}
